{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": true,
  "bracketSpacing": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 80,
  "ignorePatterns": [],
  "sortImports": {
    "groups": [
      ["builtin", "external"],
      ["internal"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "./src/styles.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": false
  }
}
