# APP Name
APP_NAME=

# Database URL for PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/mydb"

# Database driver: neon-http | node-postgres
# Optional; defaults to neon-http for *.neon.tech URLs, node-postgres otherwise
DATABASE_DRIVER=

# Better Auth configuration

BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `pnpm dlx @better-auth/cli secret`
CERTIFICATE_MASTER_KEY= # 32 random bytes encoded as base64url, e.g. `openssl rand -base64 32 | tr '+/' '-_' | tr -d '='`
CLOUDFLARE_DNS_API_TOKEN= # Optional; requires DNS Edit for CLOUDFLARE_DNS_ZONE_ID
CLOUDFLARE_DNS_ZONE_ID= # Optional; both Cloudflare values enable automatic ACME DNS-01 validation

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
