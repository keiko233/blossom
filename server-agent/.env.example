# ── blossom server-agent ──────────────────────────────────────────────────────
# Copy to .env and fill in, then: docker compose up -d
#   cp .env.example .env

# Base URL of the blossom control-plane API, including the /api prefix.
AGENT_URL=https://blossom.example.com/api

# Per-server agent token — the agt_... value shown once when the server is
# created (or its token is reset) in the admin UI. Keep it secret.
AGENT_TOKEN=agt_replace_me

# Bootstrap interval used until the first /agent/config/v2 response. Afterwards
# the control plane's per-server config/heartbeat intervals take over.
AGENT_INTERVAL=60

# Log verbosity: trace | debug | info | warn | error
AGENT_LOG_LEVEL=info

# Optional explicit sing-box binary path. By default the agent tries
# ./sing-box first, then sing-box from PATH.
# AGENT_SING_BOX_PATH=/usr/local/bin/sing-box

# Durable last-known-good config directory. The Docker image/compose file already
# mounts this path as a named volume.
# AGENT_STATE_DIR=/var/lib/blossom-agent
