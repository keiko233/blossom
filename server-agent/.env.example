# ── blossom server-agent ──────────────────────────────────────────────────────
# Copy to .env and fill in, then: docker compose up -d
#   cp .env.example .env

# Base URL of the blossom control-plane API, including the /api prefix.
AGENT_URL=https://blossom.example.com/api

# Per-node agent token — the agt_... value shown once when the node is created
# in the admin UI. Keep it secret.
AGENT_TOKEN=agt_replace_me

# Log verbosity: trace | debug | info | warn | error
AGENT_LOG_LEVEL=info
