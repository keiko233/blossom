{
  "servers": [
    {
      "url": "http://localhost:3000/api"
    }
  ],
  "info": {
    "title": "Blossom API",
    "version": "1.0.0"
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Todo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "UndefinedError": {
        "type": "object",
        "properties": {
          "defined": {
            "const": false
          },
          "code": {
            "type": "string"
          },
          "status": {
            "type": "number"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        },
        "required": [
          "defined",
          "code",
          "status",
          "message"
        ]
      }
    }
  },
  "openapi": "3.0.3",
  "paths": {
    "/listTodos": {
      "post": {
        "operationId": "listTodos",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {},
                    {
                      "not": {}
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/addTodo": {
      "post": {
        "operationId": "addTodo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {},
                    {
                      "not": {}
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/agent/config": {
      "get": {
        "operationId": "getAgentConfig",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {}
                }
              }
            }
          }
        }
      }
    },
    "/agent/config/v2": {
      "get": {
        "operationId": "getAgentConfigV2",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apiVersion": {
                      "enum": [
                        2
                      ]
                    },
                    "agent": {
                      "type": "object",
                      "properties": {
                        "configPollIntervalSeconds": {
                          "type": "integer",
                          "minimum": -9007199254740991,
                          "maximum": 9007199254740991
                        },
                        "heartbeatIntervalSeconds": {
                          "type": "integer",
                          "minimum": -9007199254740991,
                          "maximum": 9007199254740991
                        }
                      },
                      "required": [
                        "configPollIntervalSeconds",
                        "heartbeatIntervalSeconds"
                      ]
                    },
                    "singbox": {
                      "type": "object",
                      "properties": {
                        "revision": {
                          "type": "string"
                        },
                        "materializedNodeIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "config": {
                          "type": "object",
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "revision",
                        "materializedNodeIds",
                        "config"
                      ]
                    },
                    "actions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "type"
                        ],
                        "additionalProperties": {}
                      }
                    }
                  },
                  "required": [
                    "apiVersion",
                    "agent",
                    "singbox",
                    "actions"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/agent/heartbeat": {
      "post": {
        "operationId": "agentHeartbeat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "agentVersion": {
                    "type": "string"
                  },
                  "singBoxVersion": {
                    "type": "string"
                  },
                  "runtimeState": {
                    "enum": [
                      "unknown",
                      "starting",
                      "running",
                      "stopped",
                      "crash_loop"
                    ],
                    "type": "string"
                  },
                  "configState": {
                    "enum": [
                      "unknown",
                      "applied",
                      "rejected",
                      "apply_failed"
                    ],
                    "type": "string"
                  },
                  "observedRevision": {
                    "type": "string",
                    "maxLength": 128
                  },
                  "appliedRevision": {
                    "type": "string",
                    "maxLength": 128
                  },
                  "activeNodeIds": {
                    "type": "array",
                    "maxItems": 10000,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "clearActiveNodeIds": {
                    "type": "boolean"
                  },
                  "effectiveConfigPollIntervalSeconds": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 86400
                  },
                  "effectiveHeartbeatIntervalSeconds": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 3600
                  },
                  "appliedAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "clearError": {
                    "type": "boolean"
                  },
                  "error": {
                    "type": "object",
                    "properties": {
                      "phase": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 64
                      },
                      "code": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 128
                      },
                      "message": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 16384
                      },
                      "nodeId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "occurredAt": {
                        "type": "string",
                        "format": "date-time"
                      }
                    },
                    "required": [
                      "phase",
                      "code",
                      "message"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/agent/traffic": {
      "post": {
        "operationId": "reportAgentTraffic",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "windowStartedAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "windowEndedAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "entries": {
                    "type": "array",
                    "maxItems": 10000,
                    "items": {
                      "type": "object",
                      "properties": {
                        "subscriptionId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "uplinkBytes": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "downlinkBytes": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        }
                      },
                      "required": [
                        "subscriptionId",
                        "uplinkBytes",
                        "downlinkBytes"
                      ]
                    }
                  }
                },
                "required": [
                  "entries"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accepted": {
                      "type": "integer",
                      "minimum": -9007199254740991,
                      "maximum": 9007199254740991
                    },
                    "dropped": {
                      "type": "integer",
                      "minimum": -9007199254740991,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "accepted",
                    "dropped"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}